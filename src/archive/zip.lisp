;;;; zip.lisp — pure-CL ZIP (store + deflate) create/extract (Phase 74 / issue #134).

(in-package :clun.archive)

(defun %u16le-bytes (n)
  (vector (logand n #xff) (logand (ash n -8) #xff)))

(defun %u32le-bytes (n)
  (vector (logand n #xff) (logand (ash n -8) #xff)
          (logand (ash n -16) #xff) (logand (ash n -24) #xff)))

(defun %crc32-u32 (octets)
  (let ((be (ironclad:digest-sequence :crc32 octets)))
    (logior (ash (aref be 0) 24)
            (ash (aref be 1) 16)
            (ash (aref be 2) 8)
            (aref be 3))))

(defun %emit-bytes (out seq)
  (loop for b across seq do (vector-push-extend b out)))

(defun %ascii-bytes (s)
  (let ((o (make-array (length s) :element-type '(unsigned-byte 8))))
    (dotimes (i (length s) o)
      (let ((c (char-code (char s i))))
        (when (> c 127)
          (error 'tb:tarball-error
                 :message (format nil "ZIP path must be ASCII: ~s" s)))
        (setf (aref o i) c)))))

(defstruct zip-centry
  name data method compressed crc local-offset)

(defun build-zip (entries &key (method 8))
  "Build a ZIP from ENTRIES (list of (path . data)). METHOD 0=store, 8=deflate."
  (let ((out (make-array 0 :element-type '(unsigned-byte 8) :adjustable t :fill-pointer 0))
        (zentries '())
        (method (cond ((or (eql method 0) (eq method :store)) 0)
                      ((or (eql method 8) (eq method :deflate)) 8)
                      (t (error 'tb:tarball-error
                                :message (format nil "bad zip method: ~s" method))))))
    (dolist (e entries)
      (let* ((path (if (and (consp e) (eq (car e) :file)) (cadr e) (car e)))
             (raw (if (and (consp e) (eq (car e) :file)) (caddr e) (cdr e)))
             (data (if (stringp raw)
                       (sb-ext:string-to-octets raw :external-format :utf-8)
                       (coerce raw '(simple-array (unsigned-byte 8) (*)))))
             (crc (%crc32-u32 data))
             (compressed (if (= method 0) data (cmp:raw-deflate-compress data)))
             (meth (if (= method 0) 0 8))
             (local-off (fill-pointer out))
             (name-bytes (%ascii-bytes path))
             (nlen (length path))
             (csize (length compressed))
             (usize (length data)))
        (%emit-bytes out #(#x50 #x4b #x03 #x04))
        (%emit-bytes out (%u16le-bytes 20))
        (%emit-bytes out (%u16le-bytes 0))
        (%emit-bytes out (%u16le-bytes meth))
        (%emit-bytes out (%u16le-bytes 0))
        (%emit-bytes out (%u16le-bytes 0))
        (%emit-bytes out (%u32le-bytes crc))
        (%emit-bytes out (%u32le-bytes csize))
        (%emit-bytes out (%u32le-bytes usize))
        (%emit-bytes out (%u16le-bytes nlen))
        (%emit-bytes out (%u16le-bytes 0))
        (%emit-bytes out name-bytes)
        (%emit-bytes out compressed)
        (push (make-zip-centry :name path :data data :method meth
                               :compressed compressed :crc crc
                               :local-offset local-off)
              zentries)))
    (setf zentries (nreverse zentries))
    (let ((cd-start (fill-pointer out)))
      (dolist (ze zentries)
        (let* ((name-bytes (%ascii-bytes (zip-centry-name ze)))
               (nlen (length name-bytes))
               (csize (length (zip-centry-compressed ze)))
               (usize (length (zip-centry-data ze))))
          (%emit-bytes out #(#x50 #x4b #x01 #x02))
          (%emit-bytes out (%u16le-bytes 20))
          (%emit-bytes out (%u16le-bytes 20))
          (%emit-bytes out (%u16le-bytes 0))
          (%emit-bytes out (%u16le-bytes (zip-centry-method ze)))
          (%emit-bytes out (%u16le-bytes 0))
          (%emit-bytes out (%u16le-bytes 0))
          (%emit-bytes out (%u32le-bytes (zip-centry-crc ze)))
          (%emit-bytes out (%u32le-bytes csize))
          (%emit-bytes out (%u32le-bytes usize))
          (%emit-bytes out (%u16le-bytes nlen))
          (%emit-bytes out (%u16le-bytes 0))
          (%emit-bytes out (%u16le-bytes 0))
          (%emit-bytes out (%u16le-bytes 0))
          (%emit-bytes out (%u16le-bytes 0))
          (%emit-bytes out (%u32le-bytes 0))
          (%emit-bytes out (%u32le-bytes (zip-centry-local-offset ze)))
          (%emit-bytes out name-bytes)))
      (let ((cd-size (- (fill-pointer out) cd-start))
            (count (length zentries)))
        (%emit-bytes out #(#x50 #x4b #x05 #x06))
        (%emit-bytes out (%u16le-bytes 0))
        (%emit-bytes out (%u16le-bytes 0))
        (%emit-bytes out (%u16le-bytes count))
        (%emit-bytes out (%u16le-bytes count))
        (%emit-bytes out (%u32le-bytes cd-size))
        (%emit-bytes out (%u32le-bytes cd-start))
        (%emit-bytes out (%u16le-bytes 0))))
    (coerce out '(simple-array (unsigned-byte 8) (*)))))

(defun %read-u16le (buf off)
  (logior (aref buf off) (ash (aref buf (1+ off)) 8)))

(defun %read-u32le (buf off)
  (logior (aref buf off)
          (ash (aref buf (+ off 1)) 8)
          (ash (aref buf (+ off 2)) 16)
          (ash (aref buf (+ off 3)) 24)))

(defun %find-eocd (buf)
  (let ((n (length buf)))
    (loop for i from (- n 22) downto (max 0 (- n 65557))
          when (and (= (aref buf i) #x50)
                    (= (aref buf (+ i 1)) #x4b)
                    (= (aref buf (+ i 2)) #x05)
                    (= (aref buf (+ i 3)) #x06))
            return i
          finally (error 'tb:tarball-error
                         :message "ZIP: end of central directory not found"))))

(defun read-zip-entries (octets &key (max-bytes cmp:*max-decompressed-bytes*))
  "Parse ZIP OCTETS → list of (name uncompressed-octets)."
  (let* ((buf (coerce octets '(simple-array (unsigned-byte 8) (*))))
         (eocd (%find-eocd buf))
         (count (%read-u16le buf (+ eocd 10)))
         (cd-off (%read-u32le buf (+ eocd 16)))
         (entries '())
         (pos cd-off))
    (dotimes (_ count)
      (unless (= (%read-u32le buf pos) #x02014b50)
        (error 'tb:tarball-error :message "ZIP: bad central directory signature"))
      (let* ((method (%read-u16le buf (+ pos 10)))
             (crc (%read-u32le buf (+ pos 16)))
             (csize (%read-u32le buf (+ pos 20)))
             (usize (%read-u32le buf (+ pos 24)))
             (nlen (%read-u16le buf (+ pos 28)))
             (elen (%read-u16le buf (+ pos 30)))
             (clen (%read-u16le buf (+ pos 32)))
             (local-off (%read-u32le buf (+ pos 42)))
             (name (map 'string #'code-char
                        (subseq buf (+ pos 46) (+ pos 46 nlen))))
             (next (+ pos 46 nlen elen clen)))
        (unless (= (%read-u32le buf local-off) #x04034b50)
          (error 'tb:tarball-error
                 :message (format nil "ZIP: bad local header for ~s" name)))
        (let* ((l-nlen (%read-u16le buf (+ local-off 26)))
               (l-elen (%read-u16le buf (+ local-off 28)))
               (data-off (+ local-off 30 l-nlen l-elen))
               (comp (subseq buf data-off (+ data-off csize)))
               (raw (ecase method
                      (0 comp)
                      (8 (cmp:raw-inflate comp :max-bytes max-bytes))
                      (t (error 'tb:tarball-error
                                :message (format nil "ZIP: unsupported method ~a" method))))))
          (when (and (plusp usize) (/= (length raw) usize))
            (error 'tb:tarball-error
                   :message (format nil "ZIP: size mismatch for ~s" name)))
          (unless (= (%crc32-u32 raw) crc)
            (error 'tb:tarball-error
                   :message (format nil "ZIP: CRC mismatch for ~s" name)))
          (push (list name raw) entries)
          (setf pos next))))
    (nreverse entries)))
