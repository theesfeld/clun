;;;; ast-printer.lisp — a structural S-expression dump of the AST (PLAN.md Phase 02).
;;;; For debugging and snapshot tests; NOT the TS-strip codegen (that is Phase 09,
;;;; whitespace-preserving). ast->sexp yields a nested list mirroring the tree.

(in-package :clun.engine)

(defun ast->sexp (node)
  "Render NODE as a nested S-expression (NIL, lists, and leaves pass through)."
  (typecase node
    (null nil)
    (cons (mapcar #'ast->sexp node))
    (program `(:program ,(ast->sexp (program-body node))))
    (identifier `(:id ,(identifier-name node)))
    (private-name `(:private ,(private-name-name node)))
    (literal (case (literal-kind node)
               (:null '(:null))
               (:boolean (if (eq (literal-value node) +true+) '(:true) '(:false)))
               (:string `(:str ,(literal-value node)))
               (:number `(:num ,(literal-value node)))
               (:bigint `(:bigint ,(literal-value node)))
               (t `(:lit ,(literal-value node)))))
    (reg-exp-literal `(:regexp ,(reg-exp-literal-pattern node) ,(reg-exp-literal-flags node)))
    (this-expression '(:this))
    (super-node '(:super))
    (meta-property `(:meta ,(meta-property-meta node) ,(meta-property-property node)))
    (template-literal `(:template ,(ast->sexp (template-literal-quasis node))
                                  ,(ast->sexp (template-literal-expressions node))))
    (template-element `(:quasi ,(template-element-cooked node)))
    (tagged-template `(:tagged ,(ast->sexp (tagged-template-tag node))
                               ,(ast->sexp (tagged-template-quasi node))))
    (array-expression `(:array ,(ast->sexp (array-expression-elements node))))
    (object-expression `(:object ,(ast->sexp (object-expression-properties node))))
    (property `(:prop ,(property-kind node) ,(ast->sexp (property-key node))
                      ,(ast->sexp (property-value node))))
    (spread-element `(:spread ,(ast->sexp (spread-element-argument node))))
    (function-node `(:function ,(and (function-node-id node)
                                     (identifier-name (function-node-id node)))
                               ,@(when (function-node-async node) '(:async))
                               ,@(when (function-node-generator node) '(:gen))
                               ,(ast->sexp (function-node-params node))
                               ,(ast->sexp (function-node-body node))))
    (arrow-function `(:arrow ,@(when (arrow-function-async node) '(:async))
                             ,(ast->sexp (arrow-function-params node))
                             ,(ast->sexp (arrow-function-body node))))
    (class-node `(:class ,(and (class-node-id node) (identifier-name (class-node-id node)))
                         ,(ast->sexp (class-node-super-class node))
                         ,(ast->sexp (class-node-body node))))
    (class-body `(:class-body ,(ast->sexp (class-body-body node))))
    (method-definition `(:method ,(method-definition-kind node)
                                 ,@(when (method-definition-static node) '(:static))
                                 ,(ast->sexp (method-definition-key node))
                                 ,(ast->sexp (method-definition-value node))))
    (unary-expression `(:unary ,(unary-expression-operator node)
                               ,(ast->sexp (unary-expression-argument node))))
    (update-expression `(:update ,(update-expression-operator node)
                                 ,(if (update-expression-prefix node) :pre :post)
                                 ,(ast->sexp (update-expression-argument node))))
    (binary-expression `(:binary ,(binary-expression-operator node)
                                 ,(ast->sexp (binary-expression-left node))
                                 ,(ast->sexp (binary-expression-right node))))
    (logical-expression `(:logical ,(logical-expression-operator node)
                                   ,(ast->sexp (logical-expression-left node))
                                   ,(ast->sexp (logical-expression-right node))))
    (assignment-expression `(:assign ,(assignment-expression-operator node)
                                     ,(ast->sexp (assignment-expression-left node))
                                     ,(ast->sexp (assignment-expression-right node))))
    (conditional-expression `(:cond ,(ast->sexp (conditional-expression-test node))
                                    ,(ast->sexp (conditional-expression-consequent node))
                                    ,(ast->sexp (conditional-expression-alternate node))))
    (sequence-expression `(:seq ,(ast->sexp (sequence-expression-expressions node))))
    (yield-expression `(:yield ,@(when (yield-expression-delegate node) '(:delegate))
                               ,(ast->sexp (yield-expression-argument node))))
    (await-expression `(:await ,(ast->sexp (await-expression-argument node))))
    (member-expression `(:member ,(if (member-expression-computed node) :computed :dot)
                                 ,(ast->sexp (member-expression-object node))
                                 ,(ast->sexp (member-expression-property node))))
    (call-expression `(:call ,(ast->sexp (call-expression-callee node))
                             ,(ast->sexp (call-expression-arguments node))))
    (new-expression `(:new ,(ast->sexp (new-expression-callee node))
                           ,(ast->sexp (new-expression-arguments node))))
    (array-pattern `(:array-pat ,(ast->sexp (array-pattern-elements node))))
    (object-pattern `(:object-pat ,(ast->sexp (object-pattern-properties node))))
    (assignment-pattern `(:default ,(ast->sexp (assignment-pattern-left node))
                                   ,(ast->sexp (assignment-pattern-right node))))
    (rest-element `(:rest ,(ast->sexp (rest-element-argument node))))
    (expression-statement `(:expr ,(ast->sexp (expression-statement-expression node))))
    (block-statement `(:block ,(ast->sexp (block-statement-body node))))
    (empty-statement '(:empty))
    (debugger-statement '(:debugger))
    (with-statement `(:with ,(ast->sexp (with-statement-object node))
                            ,(ast->sexp (with-statement-body node))))
    (return-statement `(:return ,(ast->sexp (return-statement-argument node))))
    (labeled-statement `(:label ,(labeled-statement-label node)
                                ,(ast->sexp (labeled-statement-body node))))
    (break-statement `(:break ,(break-statement-label node)))
    (continue-statement `(:continue ,(continue-statement-label node)))
    (if-statement `(:if ,(ast->sexp (if-statement-test node))
                        ,(ast->sexp (if-statement-consequent node))
                        ,(ast->sexp (if-statement-alternate node))))
    (switch-statement `(:switch ,(ast->sexp (switch-statement-discriminant node))
                                ,(ast->sexp (switch-statement-cases node))))
    (switch-case `(:case ,(ast->sexp (switch-case-test node))
                         ,(ast->sexp (switch-case-consequent node))))
    (throw-statement `(:throw ,(ast->sexp (throw-statement-argument node))))
    (try-statement `(:try ,(ast->sexp (try-statement-block node))
                          ,(ast->sexp (try-statement-handler node))
                          ,(ast->sexp (try-statement-finalizer node))))
    (catch-clause `(:catch ,(ast->sexp (catch-clause-param node))
                           ,(ast->sexp (catch-clause-body node))))
    (while-statement `(:while ,(ast->sexp (while-statement-test node))
                              ,(ast->sexp (while-statement-body node))))
    (do-while-statement `(:do-while ,(ast->sexp (do-while-statement-body node))
                                    ,(ast->sexp (do-while-statement-test node))))
    (for-statement `(:for ,(ast->sexp (for-statement-init node))
                          ,(ast->sexp (for-statement-test node))
                          ,(ast->sexp (for-statement-update node))
                          ,(ast->sexp (for-statement-body node))))
    (for-in-statement `(:for-in ,(ast->sexp (for-in-statement-left node))
                                ,(ast->sexp (for-in-statement-right node))
                                ,(ast->sexp (for-in-statement-body node))))
    (for-of-statement `(:for-of ,(ast->sexp (for-of-statement-left node))
                                ,(ast->sexp (for-of-statement-right node))
                                ,(ast->sexp (for-of-statement-body node))))
    (variable-declaration `(:var-decl ,(variable-declaration-kind node)
                                      ,(ast->sexp (variable-declaration-declarations node))))
    (variable-declarator `(:declarator ,(ast->sexp (variable-declarator-id node))
                                       ,(ast->sexp (variable-declarator-init node))))
    (import-declaration `(:import ,(ast->sexp (import-declaration-specifiers node))
                                  ,(ast->sexp (import-declaration-source node))))
    (import-specifier `(:import-spec ,(ast->sexp (import-specifier-imported node))
                                     ,(ast->sexp (import-specifier-local node))))
    (import-default-specifier `(:import-default ,(ast->sexp (import-default-specifier-local node))))
    (import-namespace-specifier `(:import-ns ,(ast->sexp (import-namespace-specifier-local node))))
    (export-named-declaration `(:export ,(ast->sexp (export-named-declaration-declaration node))
                                        ,(ast->sexp (export-named-declaration-specifiers node))
                                        ,(ast->sexp (export-named-declaration-source node))))
    (export-default-declaration `(:export-default
                                  ,(ast->sexp (export-default-declaration-declaration node))))
    (export-all-declaration `(:export-all ,(ast->sexp (export-all-declaration-exported node))
                                          ,(ast->sexp (export-all-declaration-source node))))
    (export-specifier `(:export-spec ,(ast->sexp (export-specifier-local node))
                                     ,(ast->sexp (export-specifier-exported node))))
    (t (list :unknown (type-of node)))))
