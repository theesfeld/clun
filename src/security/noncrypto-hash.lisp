     #xb8 #x08 #x46 #x74 #xf7 #x43 #x24 #x8e #xe0 #x35 #x90 #xe6 #x81 #x3a #x26 #x4c
     #x3c #x28 #x52 #xbb #x91 #xc3 #x00 #xcb #x88 #xd0 #x65 #x8b #x1b #x53 #x2e #xa3
     #x71 #x64 #x48 #x97 #xa2 #x0d #xf9 #x4e #x38 #x19 #xef #x46 #xa9 #xde #xac #xd8
     #xa8 #xfa #x76 #x3f #xe3 #x9c #x34 #x3f #xf9 #xdc #xbb #xc7 #xc7 #x0b #x4f #x1d
     #x8a #x51 #xe0 #x4b #xcd #xb4 #x59 #x31 #xc8 #x9f #x7e #xc9 #xd9 #x78 #x73 #x64
     #xea #xc5 #xac #x83 #x34 #xd3 #xeb #xc3 #xc5 #x81 #xa0 #xff #xfa #x13 #x63 #xeb
     #x17 #x0d #xdd #x51 #xb7 #xf0 #xda #x49 #xd3 #x16 #x55 #x26 #x29 #xd4 #x68 #x9e
     #x2b #x16 #xbe #x58 #x7d #x47 #xa1 #xfc #x8f #xf8 #xb8 #xd1 #x7a #xd0 #x31 #xce
     #x45 #xcb #x3a #x8f #x95 #x16 #x04 #x28 #xaf #xd7 #xfb #xca #xbb #x4b #x40 #x7e)
   '(simple-array (unsigned-byte 8) (*))))

(defun %xxh3-avalanche (h)
  (setf h (%u64 h)
        h (%u64 (logxor h (ash h -37)))
        h (%mul64 h +xxh3-mx1+))
  (%u64 (logxor h (ash h -32))))

(defun %xxh3-rrmxmx (h length)
  (setf h (%u64 h)
        h (%u64 (logxor h (%rotl64 h 49) (%rotl64 h 24)))
        h (%mul64 h +xxh3-mx2+)
        h (%u64 (logxor h (+ (ash h -35) length)))
        h (%mul64 h +xxh3-mx2+))
  (%u64 (logxor h (ash h -28))))

(defun %xxh3-mix16 (input input-offset secret secret-offset seed)
  (%mul-fold64
   (logxor (%read64le input input-offset)
           (%u64 (+ (%read64le secret secret-offset) seed)))
   (logxor (%read64le input (+ input-offset 8))
           (%u64 (- (%read64le secret (+ secret-offset 8)) seed)))))

(defun %xxh3-short (input secret seed)
  (let ((length (length input)))
    (cond
      ((> length 16)
       (let ((acc (%mul64 length +xx-p64-1+)))
         (cond
           ((<= length 128)
            (when (> length 32)
              (when (> length 64)
                (when (> length 96)
                  (incf acc (%xxh3-mix16 input 48 secret 96 seed))
                  (incf acc (%xxh3-mix16 input (- length 64) secret 112 seed)))
                (incf acc (%xxh3-mix16 input 32 secret 64 seed))
                (incf acc (%xxh3-mix16 input (- length 48) secret 80 seed)))
              (incf acc (%xxh3-mix16 input 16 secret 32 seed))
              (incf acc (%xxh3-mix16 input (- length 32) secret 48 seed)))
            (incf acc (%xxh3-mix16 input 0 secret 0 seed))
            (incf acc (%xxh3-mix16 input (- length 16) secret 16 seed))
            (%xxh3-avalanche acc))
           (t
            (dotimes (i 8)
              (incf acc (%xxh3-mix16 input (* 16 i) secret (* 16 i) seed)))
            (let ((acc-end (%xxh3-mix16 input (- length 16) secret 119 seed))
                  (rounds (floor length 16)))
              (setf acc (%xxh3-avalanche acc))
              (loop for i from 8 below rounds
                    do (incf acc-end
                             (%xxh3-mix16 input (* 16 i) secret (+ (* 16 (- i 8)) 3) seed)))
              (%xxh3-avalanche (+ acc acc-end)))))))
      ((> length 8)
       (let* ((bitflip1 (%u64 (+ (logxor (%read64le secret 24) (%read64le secret 32)) seed)))
              (bitflip2 (%u64 (- (logxor (%read64le secret 40) (%read64le secret 48)) seed)))
              (low (logxor (%read64le input 0) bitflip1))
              (high (logxor (%read64le input (- length 8)) bitflip2)))
         (%xxh3-avalanche (+ length (%swap64 low) high (%mul-fold64 low high)))))
      ((>= length 4)
       (let* ((s (%u64 (logxor seed (ash (%swap32 (%u32 seed)) 32))))
              (input1 (%read32le input 0))
              (input2 (%read32le input (- length 4)))
              (bitflip (%u64 (- (logxor (%read64le secret 8) (%read64le secret 16)) s)))
              (input64 (+ input2 (ash input1 32))))
         (%xxh3-rrmxmx (logxor input64 bitflip) length)))
      ((plusp length)
       (let* ((combined (logior (ash (aref input 0) 16)
                                (ash (aref input (ash length -1)) 24)
                                (aref input (1- length))
                                (ash length 8)))
              (bitflip (%u64 (+ (logxor (%read32le secret 0) (%read32le secret 4)) seed))))
         (%xx64-avalanche (logxor combined bitflip))))
      (t (%xx64-avalanche (logxor seed
