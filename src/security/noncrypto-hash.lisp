(defun hash-octets (algorithm bytes &optional (seed 0))
  (ecase algorithm
    ((:wyhash :default) (wyhash bytes seed))
    (:adler32 (adler32 bytes seed))
    (:crc32 (crc32 bytes seed))
    (:city-hash32 (city-hash32 bytes seed))
    (:city-hash64 (city-hash64 bytes seed))
    (:xxhash32 (xxhash32 bytes seed))
    (:xxhash64 (xxhash64 bytes seed))
    (:xxhash3 (xxhash3 bytes seed))
    (:murmur32v2 (murmur32v2 bytes seed))
    (:murmur32v3 (murmur32v3 bytes seed))
    (:murmur64v2 (murmur64v2 bytes seed))
    (:rapidhash (rapidhash bytes seed))))
