      (dotimes (stripe stripes-per-block)
        (%xxh3-accumulate acc input (+ (* block block-length) (* stripe 64))
                          secret (* stripe 8)))
      (%xxh3-scramble acc secret 128))
    (let* ((last-block (* blocks block-length))
           (stripes (floor (- (1- length) last-block) 64)))
      (dotimes (stripe stripes)
        (%xxh3-accumulate acc input (+ last-block (* stripe 64)) secret (* stripe 8))))
    (%xxh3-accumulate acc input (- length 64) secret 121)
    (let ((result (%mul64 length +xx-p64-1+)))
      (dotimes (i 4)
        (incf result
              (%mul-fold64
               (logxor (aref acc (* i 2)) (%read64le secret (+ 11 (* i 16))))
               (logxor (aref acc (1+ (* i 2))) (%read64le secret (+ 19 (* i 16)))))))
      (%xxh3-avalanche result))))

(defun xxhash3 (bytes &optional (seed 0))
  (let* ((input (%simple-octets bytes))
         ;; Bun.hash.xxHash3 deliberately truncates its seed to u32.
         (seed (%u32 seed)))
    (if (<= (length input) 240)
        (%xxh3-short input +xxh3-secret+ seed)
        (if (zerop seed)
            (%xxh3-long input +xxh3-secret+)
            (let ((secret (make-array 192 :element-type '(unsigned-byte 8))))
              (dotimes (i 12)
                (%write64le secret (* i 16)
                            (%u64 (+ (%read64le +xxh3-secret+ (* i 16)) seed)))
                (%write64le secret (+ (* i 16) 8)
                            (%u64 (- (%read64le +xxh3-secret+ (+ (* i 16) 8)) seed))))
              (%xxh3-long input secret))))))

