;;;; noncrypto-hash.lisp -- exact integer algorithms behind Clun.hash.
;;;;
;;;; The constants and algorithm shapes follow the public reference definitions
;;;; frozen by Bun c1076ce95e. All arithmetic is explicitly reduced to the
;;;; algorithm word size so results do not depend on the host word size.

(in-package :clun.hash)

(declaim (inline %u32 %u64 %mul32 %mul64 %rotl32 %rotr32 %rotl64 %rotr64
                 %read32le %read64le %mul-fold64))

(defconstant +u32-mask+ #xffffffff)
(defconstant +u64-mask+ #xffffffffffffffff)

(defun %u32 (x) (logand x +u32-mask+))
(defun %u64 (x) (logand x +u64-mask+))
(defun %mul32 (a b) (%u32 (* a b)))
(defun %mul64 (a b) (%u64 (* a b)))
(defun %rotl32 (x count)
  (let* ((n (mod count 32)) (v (%u32 x)))
    (%u32 (logior (ash v n) (ash v (- n 32))))))
(defun %rotr32 (x count) (%rotl32 x (- count)))
(defun %rotl64 (x count)
  (let* ((n (mod count 64)) (v (%u64 x)))
    (%u64 (logior (ash v n) (ash v (- n 64))))))
(defun %rotr64 (x count) (%rotl64 x (- count)))

(defun %read32le (bytes offset)
  (logior (aref bytes offset)
          (ash (aref bytes (+ offset 1)) 8)
          (ash (aref bytes (+ offset 2)) 16)
          (ash (aref bytes (+ offset 3)) 24)))

(defun %read64le (bytes offset)
  (logior (%read32le bytes offset)
          (ash (%read32le bytes (+ offset 4)) 32)))

(defun %write64le (bytes offset value)
  (dotimes (i 8 bytes)
    (setf (aref bytes (+ offset i)) (ldb (byte 8 (* i 8)) value))))

(defun %swap32 (value)
  (let ((x (%u32 value)))
    (logior (ash (ldb (byte 8 0) x) 24)
            (ash (ldb (byte 8 8) x) 16)
            (ash (ldb (byte 8 16) x) 8)
            (ldb (byte 8 24) x))))

(defun %swap64 (value)
  (let ((x (%u64 value)) (out 0))
    (dotimes (i 8 out)
      (setf out (logior (ash out 8) (ldb (byte 8 (* i 8)) x))))))

(defun %mul-fold64 (a b)
  (let ((product (* (%u64 a) (%u64 b))))
    (%u64 (logxor product (ash product -64)))))

(defun %simple-octets (bytes)
  (unless (typep bytes '(vector (unsigned-byte 8)))
    (error 'type-error :datum bytes :expected-type '(vector (unsigned-byte 8))))
  (if (typep bytes '(simple-array (unsigned-byte 8) (*)))
      bytes
      (coerce bytes '(simple-array (unsigned-byte 8) (*)))))

;;; Adler-32 / CRC-32 ----------------------------------------------------------

(defun adler32 (bytes &optional seed)
  (declare (ignore seed))
  (let ((s1 1) (s2 0) (n 0) (input (%simple-octets bytes)))
    ;; Reducing every 5,552 bytes is the zlib bound that keeps both sums small.
    (loop for byte across input
          do (incf s1 byte)
             (incf s2 s1)
             (incf n)
             (when (= n 5552)
               (setf s1 (mod s1 65521)
                     s2 (mod s2 65521)
                     n 0)))
    (logior (mod s1 65521) (ash (mod s2 65521) 16))))

(defparameter +crc32-table+
  (load-time-value
   (let ((table (make-array 256 :element-type '(unsigned-byte 32))))
     (dotimes (n 256 table)
       (let ((c n))
         (dotimes (k 8)
           (setf c (if (oddp c)
                       (logxor #xedb88320 (ash c -1))
                       (ash c -1))))
         (setf (aref table n) c))))
  t))

(defun crc32 (bytes &optional (seed 0))
  (let ((crc (logxor (%u32 seed) +u32-mask+)))
    (loop for byte across (%simple-octets bytes)
          do (setf crc
                   (logxor (aref +crc32-table+ (logand (logxor crc byte) #xff))
                           (ash crc -8))))
    (%u32 (logxor crc +u32-mask+))))

;;; MurmurHash ----------------------------------------------------------------

(defconstant +murmur-default-seed+ #xc70f6907)

(defun %fmix32 (h)
  (setf h (%u32 (logxor h (ash h -16)))
        h (%mul32 h #x85ebca6b)
        h (%u32 (logxor h (ash h -13)))
        h (%mul32 h #xc2b2ae35))
  (%u32 (logxor h (ash h -16))))

(defun murmur32v2 (bytes &optional (seed 0))
  (let* ((input (%simple-octets bytes))
         (length (length input))
         (h (%u32 (logxor seed length)))
         (offset 0)
         (m #x5bd1e995))
    (loop while (<= (+ offset 4) length)
          for k = (%read32le input offset)
          do (setf k (%mul32 k m)
                   k (%u32 (logxor k (ash k -24)))
                   k (%mul32 k m)
                   h (%u32 (logxor (%mul32 h m) k)))
             (incf offset 4))
    (case (- length offset)
      (3 (setf h (logxor h (ash (aref input (+ offset 2)) 16)))
         (setf h (logxor h (ash (aref input (+ offset 1)) 8)))
         (setf h (logxor h (aref input offset)))
         (setf h (%mul32 h m)))
      (2 (setf h (logxor h (ash (aref input (+ offset 1)) 8)))
         (setf h (logxor h (aref input offset)))
         (setf h (%mul32 h m)))
      (1 (setf h (%mul32 (logxor h (aref input offset)) m))))
    (setf h (%u32 (logxor h (ash h -13)))
          h (%mul32 h m))
    (%u32 (logxor h (ash h -15)))))

(defun murmur64v2 (bytes &optional (seed 0))
  (let* ((input (%simple-octets bytes))
         (length (length input))
         (m #xc6a4a7935bd1e995)
         (h (%u64 (logxor seed (%mul64 length m))))
         (offset 0))
    (loop while (<= (+ offset 8) length)
          for k = (%read64le input offset)
          do (setf k (%mul64 k m)
                   k (%u64 (logxor k (ash k -47)))
                   k (%mul64 k m)
                   h (%mul64 (logxor h k) m))
             (incf offset 8))
    (let ((tail 0))
      (loop for i from offset below length
            for shift from 0 by 8
            do (setf tail (logior tail (ash (aref input i) shift))))
      (when (< offset length)
        (setf h (%mul64 (logxor h tail) m))))
    (setf h (%u64 (logxor h (ash h -47)))
          h (%mul64 h m))
    (%u64 (logxor h (ash h -47)))))

(defun murmur32v3 (bytes &optional (seed 0))
  (let* ((input (%simple-octets bytes))
         (length (length input))
         (h (%u32 seed))
         (offset 0)
         (c1 #xcc9e2d51)
         (c2 #x1b873593))
    (loop while (<= (+ offset 4) length)
          for k = (%read32le input offset)
          do (setf k (%mul32 k c1)
                   k (%rotl32 k 15)
                   k (%mul32 k c2)
                   h (%u32 (logxor h k))
                   h (%rotl32 h 13)
                   h (%u32 (+ (%mul32 h 5) #xe6546b64)))
             (incf offset 4))
    (let ((k 0))
      (case (- length offset)
        (3 (setf k (logior (ash (aref input (+ offset 2)) 16)
                            (ash (aref input (+ offset 1)) 8)
                            (aref input offset))))
        (2 (setf k (logior (ash (aref input (+ offset 1)) 8)
                            (aref input offset))))
        (1 (setf k (aref input offset))))
      (unless (zerop k)
        (setf k (%mul32 k c1)
              k (%rotl32 k 15)
              k (%mul32 k c2)
              h (%u32 (logxor h k)))))
    (%fmix32 (logxor h length))))

;;; RapidHash and wyhash -------------------------------------------------------

(defparameter +rapid-secret+
  #(#x2d358dccaa6c78a5 #x8bb84b93962eacc9 #x4b33a62ed433d4a3))

(defun rapidhash (bytes &optional (seed 0))
  (let* ((input (%simple-octets bytes))
         (length (length input))
         (s0 (%u64 (logxor seed
                           (%mul-fold64 (logxor seed (aref +rapid-secret+ 0))
                                        (aref +rapid-secret+ 1))
                           length)))
         (s1 s0) (s2 s0) (offset 0) (remaining length) (a 0) (b 0))
    (if (<= length 16)
        (cond
          ((>= length 4)
           (let* ((d (ash (logand length 24) (- (ash length -3))))
                  (e (- length 4)))
             (setf a (logior (ash (%read32le input 0) 32) (%read32le input e))
                   b (logior (ash (%read32le input d) 32) (%read32le input (- e d))))))
          ((plusp length)
           (setf a (logior (ash (aref input 0) 56)
                           (ash (aref input (ash length -1)) 32)
                           (aref input (1- length))))))
        (progn
          (when (> length 48)
            (loop while (>= remaining 96)
                  do (setf s0 (%mul-fold64
                               (logxor (%read64le input offset) (aref +rapid-secret+ 0))
                               (logxor (%read64le input (+ offset 8)) s0))
                           s1 (%mul-fold64
                               (logxor (%read64le input (+ offset 16)) (aref +rapid-secret+ 1))
                               (logxor (%read64le input (+ offset 24)) s1))
                           s2 (%mul-fold64
                               (logxor (%read64le input (+ offset 32)) (aref +rapid-secret+ 2))
                               (logxor (%read64le input (+ offset 40)) s2))
                           s0 (%mul-fold64
                               (logxor (%read64le input (+ offset 48)) (aref +rapid-secret+ 0))
                               (logxor (%read64le input (+ offset 56)) s0))
                           s1 (%mul-fold64
                               (logxor (%read64le input (+ offset 64)) (aref +rapid-secret+ 1))
                               (logxor (%read64le input (+ offset 72)) s1))
                           s2 (%mul-fold64
                               (logxor (%read64le input (+ offset 80)) (aref +rapid-secret+ 2))
                               (logxor (%read64le input (+ offset 88)) s2)))
                     (incf offset 96)
                     (decf remaining 96))
            (when (>= remaining 48)
              (setf s0 (%mul-fold64
                        (logxor (%read64le input offset) (aref +rapid-secret+ 0))
                        (logxor (%read64le input (+ offset 8)) s0))
                    s1 (%mul-fold64
                        (logxor (%read64le input (+ offset 16)) (aref +rapid-secret+ 1))
                        (logxor (%read64le input (+ offset 24)) s1))
                    s2 (%mul-fold64
                        (logxor (%read64le input (+ offset 32)) (aref +rapid-secret+ 2))
                        (logxor (%read64le input (+ offset 40)) s2)))
              (incf offset 48)
              (decf remaining 48))
            (setf s0 (%u64 (logxor s0 s1 s2))))
          (when (> remaining 16)
            (setf s0 (%mul-fold64
                      (logxor (%read64le input offset) (aref +rapid-secret+ 2))
                      (logxor (%read64le input (+ offset 8)) s0 (aref +rapid-secret+ 1))))
            (when (> remaining 32)
              (setf s0 (%mul-fold64
                        (logxor (%read64le input (+ offset 16)) (aref +rapid-secret+ 2))
                        (logxor (%read64le input (+ offset 24)) s0)))))
          (setf a (%read64le input (- length 16))
                b (%read64le input (- length 8)))))
    (let* ((product (* (%u64 (logxor a (aref +rapid-secret+ 1)))
                       (%u64 (logxor b s0))))
           (low (%u64 product))
           (high (%u64 (ash product -64))))
      (%mul-fold64 (logxor low (aref +rapid-secret+ 0) length)
                   (logxor high (aref +rapid-secret+ 1))))))

(defparameter +wy-secret+
  #(#xa0761d6478bd642f #xe7037ed1a0b428db
    #x8ebc6af09c88c6e3 #x589965cc75374cc3))

(defun wyhash (bytes &optional (seed 0))
  (let* ((input (%simple-octets bytes))
         (length (length input))
         (state0 (%u64 (logxor seed
                               (%mul-fold64 (logxor seed (aref +wy-secret+ 0))
                                            (aref +wy-secret+ 1)))))
         (state1 state0) (state2 state0) (a 0) (b 0))
    (if (<= length 16)
        (cond
          ((>= length 4)
           (let ((end (- length 4))
                 (quarter (ash (ash length -3) 2)))
             (setf a (logior (ash (%read32le input 0) 32)
                             (%read32le input quarter))
                   b (logior (ash (%read32le input end) 32)
                             (%read32le input (- end quarter))))))
          ((plusp length)
           (setf a (logior (ash (aref input 0) 16)
                           (ash (aref input (ash length -1)) 8)
                           (aref input (1- length))))))
        (let ((offset 0))
          (when (>= length 48)
            (loop while (< offset (- length 48))
                  do (setf state0 (%mul-fold64
                                   (logxor (%read64le input offset) (aref +wy-secret+ 1))
                                   (logxor (%read64le input (+ offset 8)) state0))
                           state1 (%mul-fold64
                                   (logxor (%read64le input (+ offset 16)) (aref +wy-secret+ 2))
                                   (logxor (%read64le input (+ offset 24)) state1))
                           state2 (%mul-fold64
                                   (logxor (%read64le input (+ offset 32)) (aref +wy-secret+ 3))
                                   (logxor (%read64le input (+ offset 40)) state2)))
                     (incf offset 48))
            (setf state0 (%u64 (logxor state0 state1 state2))))
          (loop while (< (+ offset 16) length)
                do (setf state0 (%mul-fold64
                                 (logxor (%read64le input offset) (aref +wy-secret+ 1))
                                 (logxor (%read64le input (+ offset 8)) state0)))
                   (incf offset 16))
          (setf a (%read64le input (- length 16))
                b (%read64le input (- length 8)))))
    (let* ((product (* (%u64 (logxor a (aref +wy-secret+ 1)))
                       (%u64 (logxor b state0))))
           (low (%u64 product))
           (high (%u64 (ash product -64))))
      (%mul-fold64 (logxor low (aref +wy-secret+ 0) length)
                   (logxor high (aref +wy-secret+ 1))))))

;;; Classic xxHash ------------------------------------------------------------

(defconstant +xx-p32-1+ #x9e3779b1)
(defconstant +xx-p32-2+ #x85ebca77)
(defconstant +xx-p32-3+ #xc2b2ae3d)
(defconstant +xx-p32-4+ #x27d4eb2f)
(defconstant +xx-p32-5+ #x165667b1)
(defconstant +xx-p64-1+ #x9e3779b185ebca87)
(defconstant +xx-p64-2+ #xc2b2ae3d27d4eb4f)
(defconstant +xx-p64-3+ #x165667b19e3779f9)
(defconstant +xx-p64-4+ #x85ebca77c2b2ae63)
(defconstant +xx-p64-5+ #x27d4eb2f165667c5)

(defun %xx32-round (acc input)
  (%mul32 (%rotl32 (%u32 (+ acc (%mul32 input +xx-p32-2+))) 13) +xx-p32-1+))

(defun %xx32-avalanche (h)
  (setf h (%u32 (logxor h (ash h -15)))
        h (%mul32 h +xx-p32-2+)
        h (%u32 (logxor h (ash h -13)))
        h (%mul32 h +xx-p32-3+))
  (%u32 (logxor h (ash h -16))))

(defun xxhash32 (bytes &optional (seed 0))
  (let* ((input (%simple-octets bytes)) (length (length input)) (offset 0) h)
    (if (>= length 16)
        (let ((v1 (%u32 (+ seed +xx-p32-1+ +xx-p32-2+)))
              (v2 (%u32 (+ seed +xx-p32-2+)))
              (v3 (%u32 seed))
              (v4 (%u32 (- seed +xx-p32-1+))))
          (loop while (<= (+ offset 16) length)
                do (setf v1 (%xx32-round v1 (%read32le input offset))
                         v2 (%xx32-round v2 (%read32le input (+ offset 4)))
                         v3 (%xx32-round v3 (%read32le input (+ offset 8)))
                         v4 (%xx32-round v4 (%read32le input (+ offset 12))))
                   (incf offset 16))
          (setf h (%u32 (+ (%rotl32 v1 1) (%rotl32 v2 7)
                             (%rotl32 v3 12) (%rotl32 v4 18)))))
        (setf h (%u32 (+ seed +xx-p32-5+))))
    (setf h (%u32 (+ h length)))
    (loop while (<= (+ offset 4) length)
          do (setf h (%u32 (+ h (%mul32 (%read32le input offset) +xx-p32-3+)))
                   h (%mul32 (%rotl32 h 17) +xx-p32-4+))
             (incf offset 4))
    (loop while (< offset length)
          do (setf h (%u32 (+ h (* (aref input offset) +xx-p32-5+)))
                   h (%mul32 (%rotl32 h 11) +xx-p32-1+))
             (incf offset))
    (%xx32-avalanche h)))

(defun %xx64-round (acc input)
  (%mul64 (%rotl64 (%u64 (+ acc (%mul64 input +xx-p64-2+))) 31) +xx-p64-1+))

(defun %xx64-merge (acc value)
  (%u64 (+ (%mul64 (logxor acc (%xx64-round 0 value)) +xx-p64-1+)
           +xx-p64-4+)))

(defun %xx64-avalanche (h)
  (setf h (%u64 (logxor h (ash h -33)))
        h (%mul64 h +xx-p64-2+)
        h (%u64 (logxor h (ash h -29)))
        h (%mul64 h +xx-p64-3+))
  (%u64 (logxor h (ash h -32))))

(defun xxhash64 (bytes &optional (seed 0))
  (let* ((input (%simple-octets bytes)) (length (length input)) (offset 0) h)
    (if (>= length 32)
        (let ((v1 (%u64 (+ seed +xx-p64-1+ +xx-p64-2+)))
              (v2 (%u64 (+ seed +xx-p64-2+)))
              (v3 (%u64 seed))
              (v4 (%u64 (- seed +xx-p64-1+))))
          (loop while (<= (+ offset 32) length)
                do (setf v1 (%xx64-round v1 (%read64le input offset))
                         v2 (%xx64-round v2 (%read64le input (+ offset 8)))
                         v3 (%xx64-round v3 (%read64le input (+ offset 16)))
                         v4 (%xx64-round v4 (%read64le input (+ offset 24))))
                   (incf offset 32))
          (setf h (%u64 (+ (%rotl64 v1 1) (%rotl64 v2 7)
                             (%rotl64 v3 12) (%rotl64 v4 18)))
                h (%xx64-merge h v1)
                h (%xx64-merge h v2)
                h (%xx64-merge h v3)
                h (%xx64-merge h v4)))
        (setf h (%u64 (+ seed +xx-p64-5+))))
    (setf h (%u64 (+ h length)))
    (loop while (<= (+ offset 8) length)
          for k = (%xx64-round 0 (%read64le input offset))
          do (setf h (%u64 (logxor h k))
                   h (%u64 (+ (%mul64 (%rotl64 h 27) +xx-p64-1+) +xx-p64-4+)))
             (incf offset 8))
    (when (<= (+ offset 4) length)
      (setf h (%u64 (logxor h (%mul64 (%read32le input offset) +xx-p64-1+)))
            h (%u64 (+ (%mul64 (%rotl64 h 23) +xx-p64-2+) +xx-p64-3+)))
      (incf offset 4))
    (loop while (< offset length)
          do (setf h (%u64 (logxor h (%mul64 (aref input offset) +xx-p64-5+)))
                   h (%mul64 (%rotl64 h 11) +xx-p64-1+))
             (incf offset))
    (%xx64-avalanche h)))

;;; XXH3 ----------------------------------------------------------------------

(defconstant +xxh3-mx1+ #x165667919e3779f9)
(defconstant +xxh3-mx2+ #x9fb21c651e98df25)

(defparameter +xxh3-secret+
