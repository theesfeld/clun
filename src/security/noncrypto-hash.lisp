            value (%u64 (logxor value (%read64le secret (+ offset (* i 8)))))
            (aref acc i) (%mul64 value +xx-p32-1+)))))

(defun %xxh3-long (input secret)
  (let* ((length (length input))
         (acc (vector +xx-p32-3+ +xx-p64-1+ +xx-p64-2+ +xx-p64-3+
                      +xx-p64-4+ +xx-p32-2+ +xx-p64-5+ +xx-p32-1+))
         (stripes-per-block 16)
         (block-length 1024)
         (blocks (floor (1- length) block-length)))
